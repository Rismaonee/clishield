def ensure_config_dir():
    """Create the config directory if it doesn't exist."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)


def load_state():
    """Load application state from disk."""
    if STATE_FILE.exists():
        try:
            with open(STATE_FILE, "r") as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            pass
    return {
        "active": False,
        "last_update": None,
        "domains_count": 0,
        "activated_at": None,
    }


def save_state(state):
    """Persist application state."""
    ensure_config_dir()
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)


def load_sources():
    """Load blocklist sources (custom file if exists, else defaults)."""
    if CUSTOM_SOURCES.exists():
        try:
            with open(CUSTOM_SOURCES, "r") as f:
                data = json.load(f)
                return data.get("sources", DEFAULT_SOURCES)
        except (json.JSONDecodeError, IOError):
            pass
    return DEFAULT_SOURCES


def load_whitelist():
    """Load user-defined whitelist."""
    if WHITELIST_FILE.exists():
        with open(WHITELIST_FILE, "r") as f:
            return set(
                line.strip().lower()
                for line in f
                if line.strip() and not line.startswith("#")
            )
    return set()


def save_whitelist(domains):
    """Save user whitelist to disk."""
    ensure_config_dir()
    with open(WHITELIST_FILE, "w") as f:
        f.write("# CliShield Whitelist\n")
        f.write("# One domain per line. These domains will NOT be blocked.\n")
        f.write(f"# Updated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n")
        for domain in sorted(domains):
            f.write(f"{domain}\n")


# ═══════════════════════════════════════════════════════════════════════════════
#  Blocklist Management
# ═══════════════════════════════════════════════════════════════════════════════


def is_valid_domain(domain):
    """Validate a domain string."""
    if not domain or len(domain) > 253:
        return False
    if domain in SAFETY_WHITELIST:
        return False
    if not re.match(r"^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$", domain):
        return False
    if "." not in domain:
        return False
    if ".." in domain:
        return False
    return True


def parse_hosts_content(content):
    """Parse domains from hosts-format or adblock-format content."""
    domains = set()

    for line in content.splitlines():
        line = line.strip()

        # Skip blanks, comments, and metadata
        if not line or line.startswith(("#", "!", "//", ";")):
            continue

        # Hosts format: "0.0.0.0 domain.com" or "127.0.0.1 domain.com"
        if line.startswith(("0.0.0.0", "127.0.0.1")):
            parts = line.split()
            if len(parts) >= 2:
                # Handle inline comments: "0.0.0.0 domain.com # comment"
                domain = parts[1].strip().lower()
                if is_valid_domain(domain):
                    domains.add(domain)
            continue

        # Adblock filter format: "||domain.com^"
        match = re.match(r"^\|\|([a-zA-Z0-9._-]+)\^", line)
        if match:
            domain = match.group(1).strip().lower()
            if is_valid_domain(domain):
                domains.add(domain)
            continue

        # Plain domain format (one per line)
        candidate = line.split("#")[0].strip().lower()
        if is_valid_domain(candidate):
            domains.add(candidate)

    return domains


def download_blocklists():
    """Download all enabled blocklist sources and merge them."""
    sources = load_sources()
    all_domains = set()
    total = sum(1 for s in sources if s.get("enabled", True))
    completed = 0

    for source in sources:
        if not source.get("enabled", True):
            continue

        name = source["name"]
        url = source["url"]
        log_step(f"Downloading: {Style.BOLD}{name}{Style.RESET}")

        try:
            req = urllib.request.Request(
                url,
                headers={
                    "User-Agent": f"CliShield/{VERSION} (https://github.com/clishield)",
                    "Accept": "text/plain",
                },
            )
            with urllib.request.urlopen(req, timeout=30) as response:
                content = response.read().decode("utf-8", errors="ignore")

            domains = parse_hosts_content(content)
            all_domains.update(domains)
            completed += 1
            log_success(
                f"Loaded {Style.BOLD}{len(domains):,}{Style.RESET} domains"
                f"  {Style.DIM}[{completed}/{total}]{Style.RESET}"
            )

        except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
            completed += 1
            log_warn(f"Failed: {Style.DIM}{e}{Style.RESET}  [{completed}/{total}]")
            continue

    # Remove safety whitelist domains
    all_domains -= SAFETY_WHITELIST

    # Remove user whitelisted domains
    user_whitelist = load_whitelist()
    removed = all_domains & user_whitelist
    all_domains -= user_whitelist

    if removed:
        log_info(
            f"Excluded {Style.BOLD}{len(removed)}{Style.RESET} whitelisted "
            f"domain{'s' if len(removed) != 1 else ''}"
        )

    return all_domains


def cache_blocklist(domains):
    """Write the merged blocklist to a local cache file."""
    ensure_config_dir()
    with open(BLOCKLIST_CACHE, "w") as f:
        for domain in sorted(domains):
            f.write(f"{domain}\n")


def load_cached_blocklist():
    """Load domains from the local blocklist cache."""
    if BLOCKLIST_CACHE.exists():
        with open(BLOCKLIST_CACHE, "r") as f:
            return set(line.strip() for line in f if line.strip())
    return None


# ═══════════════════════════════════════════════════════════════════════════════
#  Hosts File Management
# ═══════════════════════════════════════════════════════════════════════════════


def read_hosts_file():
    """Read the system hosts file."""
    hosts_path = get_hosts_path()
    try:
        with open(hosts_path, "r") as f:
            return f.read()
    except IOError as e:
        log_error(f"Cannot read hosts file: {e}")
        sys.exit(1)


def backup_hosts():
    """Create a one-time backup of the original hosts file."""
    ensure_config_dir()
    if not HOSTS_BACKUP.exists():
        content = read_hosts_file()
        clean = extract_original_hosts(content)
        with open(HOSTS_BACKUP, "w") as f:
            f.write(clean)
        log_success(f"Backed up original hosts → {Style.DIM}{HOSTS_BACKUP}{Style.RESET}")
    else:
        log_info(f"Backup already exists at {Style.DIM}{HOSTS_BACKUP}{Style.RESET}")


def extract_original_hosts(content):
    """Strip CliShield-managed blocks from hosts content."""
    lines = content.splitlines(True)
    result = []
    in_block = False

    for line in lines:
        if MARKER_START in line:
            in_block = True
            continue
        if MARKER_END in line:
            in_block = False
            continue
        if not in_block:
            result.append(line)

    text = "".join(result).rstrip("\n")
    return text + "\n" if text else ""


def write_hosts_file(content):
    """Safely overwrite the system hosts file."""
    hosts_path = get_hosts_path()
    tmp_path = None

    try:
        fd, tmp_path = tempfile.mkstemp(prefix="clishield_hosts_", text=True)
        with os.fdopen(fd, "w") as f:
            f.write(content)

        # Preserve original file permissions
        try:
            original_stat = os.stat(hosts_path)
            os.chmod(tmp_path, original_stat.st_mode)
            if hasattr(os, "chown"):
                os.chown(tmp_path, original_stat.st_uid, original_stat.st_gid)
        except (OSError, AttributeError):
            pass

        shutil.move(tmp_path, str(hosts_path))
        return True

    except (IOError, OSError) as e:
        log_error(f"Cannot write hosts file: {e}")
        if tmp_path:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
        return False


def inject_blocklist(domains):
    """Inject the blocklist into the system hosts file."""
    current = read_hosts_file()
    original = extract_original_hosts(current)

    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    block_lines = [
        "",
        MARKER_START,
        f"# Managed by CliShield v{VERSION}",
        f"# Last updated: {now}",
        f"# Blocked domains: {len(domains):,}",
        f"# Do not edit this section manually — use 'clishield' CLI",
        "#",
    ]

    for domain in sorted(domains):
        block_lines.append(f"{REDIRECT_IP} {domain}")

    block_lines.append(MARKER_END)
    block_lines.append("")

    new_content = original.rstrip("\n") + "\n" + "\n".join(block_lines)
    return write_hosts_file(new_content)


def remove_blocklist():
    """Remove the CliShield block from the hosts file."""
    current = read_hosts_file()
    clean = extract_original_hosts(current)
    return write_hosts_file(clean)


