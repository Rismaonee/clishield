def cmd_activate(args=None):
    """Enable ad blocking."""
    require_root()
    print_banner()

    state = load_state()

    if state.get("active"):
        log_warn("CliShield is already active.")
        log_info(f"Use {Style.BOLD}sudo clishield update{Style.RESET} to refresh blocklists.")
        print()
        return

    log_step(f"Activating CliShield...{Style.RESET}")
    print()

    # 1. Backup
    backup_hosts()

    # 2. Download blocklists
    print()
    log_info("Fetching blocklists from sources...")
    print()
    domains = download_blocklists()

    if not domains:
        print()
        log_error("No domains loaded. Check your internet connection.")
        sys.exit(1)

    print()
    log_info(f"Total unique domains to block: {Style.BOLD}{len(domains):,}{Style.RESET}")

    # 3. Cache
    cache_blocklist(domains)

    # 4. Inject into hosts
    log_step("Updating hosts file...")
    if not inject_blocklist(domains):
        sys.exit(1)
    log_success("Hosts file updated successfully.")

    # 5. Flush DNS
    log_step("Flushing DNS cache...")
    if flush_dns_cache():
        log_success("DNS cache flushed.")
    else:
        log_warn("Could not flush DNS cache automatically.")
        log_info("You may need to restart your browser or network service.")

    # 6. Save state
    now = datetime.now(timezone.utc).isoformat()
    state["active"] = True
    state["last_update"] = now
    state["activated_at"] = now
    state["domains_count"] = len(domains)
    save_state(state)

    print()
    print_divider()
    print(
        f"  {Style.GREEN}{Style.BOLD}🛡  CliShield is now ACTIVE{Style.RESET}"
    )
    print(
        f"  {Style.DIM}   Blocking {len(domains):,} ad & tracker domains system-wide{Style.RESET}"
    )
    print_divider()
    print()
    log_info(f"Deactivate anytime: {Style.BOLD}sudo clishield --inactive{Style.RESET}")
    print()


def cmd_deactivate(args=None):
    """Disable ad blocking."""
    require_root()
    print_banner()

    state = load_state()

    if not state.get("active"):
        log_warn("CliShield is already inactive.")
        print()
        return

    log_step("Deactivating CliShield...")

    # Remove from hosts
    if not remove_blocklist():
        sys.exit(1)
    log_success("Hosts file restored to original state.")

    # Flush DNS
    log_step("Flushing DNS cache...")
    if flush_dns_cache():
        log_success("DNS cache flushed.")
    else:
        log_warn("Could not flush DNS cache automatically.")

    # Update state
    state["active"] = False
    save_state(state)

    print()
    print_divider()
    print(f"  {Style.YELLOW}{Style.BOLD}⊘  CliShield is now INACTIVE{Style.RESET}")
    print(
        f"  {Style.DIM}   Ad blocking disabled. Hosts file restored.{Style.RESET}"
    )
    print_divider()
    print()
    log_info(f"Re-activate: {Style.BOLD}sudo clishield --active{Style.RESET}")
    print()


def cmd_status(args=None):
    """Display current CliShield status."""
    print_banner()

    state = load_state()
    is_active = state.get("active", False)

    # Status badge
    if is_active:
        print(
            f"  {Style.BG_GREEN}{Style.WHITE}{Style.BOLD} {Style.ACTIVE} ACTIVE "
            f"{Style.RESET}"
        )
    else:
        print(
            f"  {Style.BG_RED}{Style.WHITE}{Style.BOLD} {Style.ACTIVE} INACTIVE "
            f"{Style.RESET}"
        )
    print()

    # Details
    domains = state.get("domains_count", 0)
    last_update = state.get("last_update", "Never")
    activated_at = state.get("activated_at", "Never")

    # Format timestamps
    for label, val in [("last_update", last_update), ("activated_at", activated_at)]:
        if val and val not in ("Never", None):
            try:
                dt = datetime.fromisoformat(val)
                formatted = dt.strftime("%Y-%m-%d %H:%M:%S UTC")
                if label == "last_update":
                    last_update = formatted
                else:
                    activated_at = formatted
            except (ValueError, TypeError):
                pass

    print_divider()
    print(f"  {Style.BOLD}Blocked domains:{Style.RESET}   {domains:,}")
    print(f"  {Style.BOLD}Last updated:{Style.RESET}      {last_update}")
    print(f"  {Style.BOLD}Activated at:{Style.RESET}      {activated_at}")
    print(f"  {Style.BOLD}Config dir:{Style.RESET}        {CONFIG_DIR}")
    print(f"  {Style.BOLD}Hosts file:{Style.RESET}        {get_hosts_path()}")
    print(f"  {Style.BOLD}Platform:{Style.RESET}          {get_platform()}")
    print_divider()

    # Whitelist info
    whitelist = load_whitelist()
    if whitelist:
        print(
            f"\n  {Style.BOLD}Whitelisted domains:{Style.RESET} {len(whitelist)}"
        )
        for d in sorted(whitelist)[:10]:
            print(f"    {Style.DIM}{Style.BULLET}{Style.RESET} {d}")
        if len(whitelist) > 10:
            print(
                f"    {Style.DIM}... and {len(whitelist) - 10} more{Style.RESET}"
            )

    # Sources info
    sources = load_sources()
    enabled = sum(1 for s in sources if s.get("enabled", True))
    print(f"\n  {Style.BOLD}Blocklist sources:{Style.RESET} {enabled} active")
    for s in sources:
        status = Style.GREEN + Style.CHECK if s.get("enabled", True) else Style.RED + Style.CROSS
        print(
            f"    {status}{Style.RESET} {s['name']}"
            f"  {Style.DIM}({s.get('category', 'general')}){Style.RESET}"
        )

    print()


def cmd_update(args=None):
    """Refresh blocklists with latest data."""
    require_root()
    print_banner()

    state = load_state()

    if not state.get("active"):
        log_warn("CliShield is not active. Activate first:")
        log_info(f"{Style.BOLD}sudo clishield activate{Style.RESET}")
        print()
        sys.exit(1)

    log_step("Updating blocklists...")
    print()

    # Download fresh lists
    domains = download_blocklists()

    if not domains:
        print()
        log_error("No domains loaded. Keeping existing blocklist.")
        sys.exit(1)

    print()
    log_info(f"Total unique domains: {Style.BOLD}{len(domains):,}{Style.RESET}")

    # Show diff
    old_count = state.get("domains_count", 0)
    diff = len(domains) - old_count
    if diff > 0:
        log_info(f"Change: {Style.GREEN}+{diff:,} new domains{Style.RESET}")
    elif diff < 0:
        log_info(f"Change: {Style.RED}{diff:,} domains removed{Style.RESET}")
    else:
        log_info(f"Change: {Style.DIM}no difference{Style.RESET}")

    # Cache and inject
    cache_blocklist(domains)

    log_step("Updating hosts file...")
    if not inject_blocklist(domains):
        sys.exit(1)
    log_success("Hosts file updated.")

    # Flush DNS
    log_step("Flushing DNS cache...")
    if flush_dns_cache():
        log_success("DNS cache flushed.")
    else:
        log_warn("Could not flush DNS cache.")

    # Save state
    state["last_update"] = datetime.now(timezone.utc).isoformat()
    state["domains_count"] = len(domains)
    save_state(state)

    print()
    log_success(
        f"Blocklists updated! Now blocking {Style.BOLD}{len(domains):,}{Style.RESET} domains."
    )
    print()


def cmd_whitelist(args):
    """Manage the domain whitelist."""
    print_banner()

    whitelist = load_whitelist()

    # --list flag
    if args.list:
        if not whitelist:
            log_info("Whitelist is empty.")
        else:
            print(f"  {Style.BOLD}Whitelisted domains ({len(whitelist)}):{Style.RESET}\n")
            for d in sorted(whitelist):
                print(f"    {Style.DIM}{Style.BULLET}{Style.RESET} {d}")
        print()
        return

    # Need a domain for add/remove
    if not args.domain:
        log_error("Please specify a domain.")
        log_info(f"Usage: {Style.BOLD}clishield whitelist <domain>{Style.RESET}")
        log_info(f"       {Style.BOLD}clishield whitelist --list{Style.RESET}")
        print()
        return

    domain = args.domain.lower().strip()

    # --remove flag
    if args.remove:
        if domain in whitelist:
            whitelist.discard(domain)
            save_whitelist(whitelist)
            log_success(f"Removed {Style.BOLD}{domain}{Style.RESET} from whitelist.")
        else:
            log_warn(f"{Style.BOLD}{domain}{Style.RESET} is not in the whitelist.")
        log_info(f"Run {Style.BOLD}sudo clishield update{Style.RESET} to apply changes.")
        print()
        return

    # Add to whitelist
    whitelist.add(domain)
    save_whitelist(whitelist)
    log_success(f"Added {Style.BOLD}{domain}{Style.RESET} to whitelist.")
    log_info(f"Run {Style.BOLD}sudo clishield update{Style.RESET} to apply changes.")
    print()


def cmd_stats(args=None):
    """Show detailed blocking statistics."""
    print_banner()

    state = load_state()
    cached = load_cached_blocklist()

    if not cached:
        log_info("No blocklist data. Run 'sudo clishield activate' first.")
        print()
        return

    total = len(cached)

    print(f"  {Style.BOLD}📊 Blocking Statistics{Style.RESET}")
    print_divider()
    print()
    print(f"  {Style.BOLD}Total blocked domains:{Style.RESET}  {total:,}")

    # Status
    status_str = (
        f"{Style.GREEN}🟢 Active{Style.RESET}"
        if state.get("active")
        else f"{Style.RED}🔴 Inactive{Style.RESET}"
    )
    print(f"  {Style.BOLD}Status:{Style.RESET}                {status_str}")
    print()

    # TLD breakdown
    tld_counts = {}
    for domain in cached:
        parts = domain.rsplit(".", 1)
        tld = parts[-1] if len(parts) > 1 else "other"
        tld_counts[tld] = tld_counts.get(tld, 0) + 1

    top_tlds = sorted(tld_counts.items(), key=lambda x: x[1], reverse=True)[:15]

    if top_tlds:
        print(f"  {Style.BOLD}Top TLDs:{Style.RESET}")
        max_count = top_tlds[0][1]
        bar_width = 28

        for tld, count in top_tlds:
            bar_len = int((count / max_count) * bar_width)
            bar = Style.BAR_FULL * bar_len + Style.BAR_EMPTY * (bar_width - bar_len)
            pct = (count / total) * 100
            print(
                f"    {Style.CYAN}.{tld:6s}{Style.RESET} "
                f"{bar} {count:>8,}  {Style.DIM}({pct:.1f}%){Style.RESET}"
            )
        print()

    # Category estimates
    categories = {
        "Advertising": ["ad.", "ads.", "adserver", "adservice", "adtrack", "doubleclick", "adsystem"],
        "Tracking": ["track", "analytics", "metric", "telemetry", "beacon", "pixel"],
        "Social Media": ["facebook", "twitter", "tiktok", "instagram", "snap"],
        "Video/Streaming": ["googlevideo", "youtube", "videoads", "vast.", "moat"],
        "Malware/Phishing": ["malware", "phish", "scam", "fraud", "exploit"],
        "Crypto Mining": ["coinhive", "cryptoloot", "miner", "coinpot"],
    }

    print(f"  {Style.BOLD}Category estimates:{Style.RESET}")
    for category, keywords in categories.items():
        count = sum(1 for d in cached if any(kw in d for kw in keywords))
        if count > 0:
            bar_len = min(int((count / total) * 200), 20)
            bar = Style.BAR_FULL * bar_len
            print(
                f"    {Style.MAGENTA}{category:20s}{Style.RESET} "
                f"{bar} ~{count:,}"
            )
    print()

    # Whitelist
    whitelist = load_whitelist()
    print(f"  {Style.BOLD}Whitelisted:{Style.RESET}  {len(whitelist)} domain{'s' if len(whitelist) != 1 else ''}")
    print()


def cmd_list_domains(args):
    """List all blocked domains."""
    cached = load_cached_blocklist()
    if not cached:
        log_info("No blocklist data. Run 'sudo clishield activate' first.")
        return

    sorted_domains = sorted(cached)

    # Apply filter
    if args.filter:
        query = args.filter.lower()
        sorted_domains = [d for d in sorted_domains if query in d]
        print(
            f"\n  Domains matching '{Style.BOLD}{query}{Style.RESET}'"
            f" ({len(sorted_domains):,} results):\n"
        )
    else:
        print(f"\n  All blocked domains ({len(sorted_domains):,}):\n")

    if not sorted_domains:
        log_info("No matching domains found.")
        print()
        return

    # Paginate output
    page_size = args.count if hasattr(args, "count") and args.count else 50
    show_all = args.all if hasattr(args, "all") else False

    for i, domain in enumerate(sorted_domains):
        if i >= page_size and not show_all:
            remaining = len(sorted_domains) - page_size
            print(
                f"\n  {Style.DIM}... and {remaining:,} more.{Style.RESET}"
            )
            print(
                f"  {Style.DIM}Use --all to show all, "
                f"or --filter <term> to search.{Style.RESET}\n"
            )
            break
        print(f"    {Style.DIM}{i + 1:>6}.{Style.RESET} {domain}")
    else:
        print()


def cmd_restore(args=None):
    """Restore the original hosts file from backup."""
    require_root()
    print_banner()

    if not HOSTS_BACKUP.exists():
        log_error("No backup found. Cannot restore.")
        print()
        return

    log_step("Restoring original hosts file from backup...")

    try:
        with open(HOSTS_BACKUP, "r") as f:
            original = f.read()
        if write_hosts_file(original):
            log_success("Hosts file restored from backup.")
            flush_dns_cache()
            state = load_state()
            state["active"] = False
            save_state(state)
        else:
            log_error("Failed to restore hosts file.")
    except IOError as e:
        log_error(f"Cannot read backup: {e}")

    print()


# ═══════════════════════════════════════════════════════════════════════════════
#  CLI Argument Parser
# ═══════════════════════════════════════════════════════════════════════════════


def build_parser():
    """Build the CLI argument parser."""
    parser = argparse.ArgumentParser(
        prog="clishield",
        description="🛡 CliShield — System-level ad & tracker blocker",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent(
            f"""\
        {Style.BOLD}examples:{Style.RESET}
          sudo clishield activate            Enable ad blocking
          sudo clishield deactivate          Disable ad blocking
          sudo clishield --active            Shorthand for activate
          sudo clishield --inactive          Shorthand for deactivate
          clishield status                   Show current status
          sudo clishield update              Refresh blocklists
          clishield whitelist spotify.com    Whitelist a domain
          clishield stats                    Show statistics
          clishield list --filter google     Search blocked domains

        {Style.BOLD}config:{Style.RESET}
          ~/.clishield/state.json            Application state
          ~/.clishield/whitelist.txt         Whitelisted domains
          ~/.clishield/sources.json          Custom blocklist sources
          ~/.clishield/hosts.original.bak    Original hosts backup
        """
        ),
    )

    parser.add_argument(
        "--version", action="version", version=f"clishield {VERSION}"
    )
    parser.add_argument(
        "--active",
        action="store_true",
        help="Activate ad blocking (shorthand for 'activate')",
    )
    parser.add_argument(
        "--inactive",
        action="store_true",
        help="Deactivate ad blocking (shorthand for 'deactivate')",
    )

    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # activate
    subparsers.add_parser("activate", help="Enable ad blocking")

    # deactivate
    subparsers.add_parser("deactivate", help="Disable ad blocking")

    # status
    subparsers.add_parser("status", help="Show current status")

    # update
    subparsers.add_parser("update", help="Update blocklists to latest")

    # whitelist
    wl = subparsers.add_parser("whitelist", help="Manage domain whitelist")
    wl.add_argument("domain", nargs="?", help="Domain to add/remove")
    wl.add_argument(
        "--remove", "-r", action="store_true", help="Remove from whitelist"
    )
    wl.add_argument(
        "--list", "-l", action="store_true", help="List all whitelisted domains"
    )

    # stats
    subparsers.add_parser("stats", help="Show blocking statistics")

    # list
    ls = subparsers.add_parser("list", help="List all blocked domains")
    ls.add_argument("--filter", "-f", help="Filter domains by keyword")
    ls.add_argument(
        "--all", "-a", action="store_true", help="Show all (no pagination)"
    )
    ls.add_argument(
        "--count", "-n", type=int, default=50, help="Number of results per page"
    )

    # restore
    subparsers.add_parser(
        "restore", help="Restore original hosts file from backup"
    )

    return parser


# ═══════════════════════════════════════════════════════════════════════════════
#  Entry Point
# ═══════════════════════════════════════════════════════════════════════════════


def main():
    """Main entry point."""
    parser = build_parser()
    args = parser.parse_args()

    # Shorthand flags
    if args.active:
        cmd_activate()
        return

    if args.inactive:
        cmd_deactivate()
        return

    # Subcommands
    command_map = {
        "activate": lambda: cmd_activate(args),
        "deactivate": lambda: cmd_deactivate(args),
        "status": lambda: cmd_status(args),
        "update": lambda: cmd_update(args),
        "whitelist": lambda: cmd_whitelist(args),
        "stats": lambda: cmd_stats(args),
        "list": lambda: cmd_list_domains(args),
        "restore": lambda: cmd_restore(args),
    }

    if args.command in command_map:
        command_map[args.command]()
    elif args.command is None:
        # No command given — show status if configured, else help
        state = load_state()
        if state.get("active") is not None and STATE_FILE.exists():
            cmd_status()
        else:
            parser.print_help()
    else:
        parser.print_help()


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n  {Style.DIM}Interrupted.{Style.RESET}\n")
        sys.exit(130)
    except Exception as e:
        log_error(f"Unexpected error: {e}")
        sys.exit(1)
