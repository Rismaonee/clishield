class Style:
    """ANSI terminal colors and symbols with auto-detection."""

    _enabled = hasattr(sys.stdout, "isatty") and sys.stdout.isatty() and os.environ.get("NO_COLOR") is None

    RESET = "\033[0m" if _enabled else ""
    BOLD = "\033[1m" if _enabled else ""
    DIM = "\033[2m" if _enabled else ""
    ITALIC = "\033[3m" if _enabled else ""
    RED = "\033[91m" if _enabled else ""
    GREEN = "\033[92m" if _enabled else ""
    YELLOW = "\033[93m" if _enabled else ""
    BLUE = "\033[94m" if _enabled else ""
    MAGENTA = "\033[95m" if _enabled else ""
    CYAN = "\033[96m" if _enabled else ""
    WHITE = "\033[97m" if _enabled else ""
    BG_GREEN = "\033[42m" if _enabled else ""
    BG_RED = "\033[41m" if _enabled else ""
    BG_YELLOW = "\033[43m" if _enabled else ""

    # Symbols
    CHECK = "✓" if _enabled else "[OK]"
    CROSS = "✗" if _enabled else "[FAIL]"
    ARROW = "→" if _enabled else "->"
    BULLET = "•" if _enabled else "*"
    SHIELD = "🛡" if _enabled else "[S]"
    BLOCK = "⊘" if _enabled else "[X]"
    INFO = "ℹ" if _enabled else "[i]"
    WARN = "⚠" if _enabled else "[!]"
    BAR_FULL = "█" if _enabled else "#"
    BAR_EMPTY = "░" if _enabled else "."
    ACTIVE = "●" if _enabled else "[*]"


def print_banner():
    """Print the CliShield banner."""
    print(
        f"""
{Style.CYAN}{Style.BOLD}  ┌──────────────────────────────────────┐
  │  {Style.WHITE}🛡  CliShield v{VERSION}{Style.CYAN}                    │
  │  {Style.RESET}{Style.DIM}  System-level ad & tracker blocker{Style.RESET}{Style.CYAN}{Style.BOLD}  │
  └──────────────────────────────────────┘{Style.RESET}
"""
    )


def log(icon, color, message):
    """Print a styled log message."""
    print(f"  {color}{icon}{Style.RESET}  {message}")


def log_success(msg):
    log(Style.CHECK, Style.GREEN, msg)


def log_error(msg):
    log(Style.CROSS, Style.RED, msg)


def log_info(msg):
    log(Style.INFO, Style.BLUE, msg)


def log_warn(msg):
    log(Style.WARN, Style.YELLOW, msg)


def log_step(msg):
    log(Style.ARROW, Style.CYAN, msg)


def print_divider(width=44):
    print(f"  {Style.DIM}{'─' * width}{Style.RESET}")


def print_progress(current, total, width=30, label=""):
    """Print a progress bar."""
    if total == 0:
        return
    ratio = current / total
    filled = int(width * ratio)
    bar = Style.BAR_FULL * filled + Style.BAR_EMPTY * (width - filled)
    pct = ratio * 100
    sys.stdout.write(f"\r  {Style.CYAN}{bar}{Style.RESET} {pct:5.1f}% {Style.DIM}{label}{Style.RESET}")
    sys.stdout.flush()
    if current == total:
        print()


# ═══════════════════════════════════════════════════════════════════════════════
#  Platform Detection
# ═══════════════════════════════════════════════════════════════════════════════


def get_platform():
    """Detect the current platform."""
    system = platform.system().lower()
    if system == "darwin":
        return "macos"
    elif system == "linux":
        return "linux"
    elif system == "windows":
        return "windows"
    return system


def get_hosts_path():
    """Get the system hosts file path."""
    if get_platform() == "windows":
        windir = os.environ.get("SystemRoot", r"C:\Windows")
        return Path(windir) / "System32" / "drivers" / "etc" / "hosts"
    return Path("/etc/hosts")


def flush_dns_cache():
    """Flush the system DNS cache."""
    plat = get_platform()
    try:
        if plat == "macos":
            subprocess.run(
                ["dscacheutil", "-flushcache"],
                capture_output=True,
                check=True,
            )
            subprocess.run(
                ["killall", "-HUP", "mDNSResponder"],
                capture_output=True,
                check=False,  # May fail if not running
            )
        elif plat == "linux":
            # Try systemd-resolved, then resolvectl, then nscd
            r = subprocess.run(["systemd-resolve", "--flush-caches"], capture_output=True)
            if r.returncode != 0:
                subprocess.run(["resolvectl", "flush-caches"], capture_output=True)
            subprocess.run(["nscd", "-i", "hosts"], capture_output=True)
        elif plat == "windows":
            subprocess.run(["ipconfig", "/flushdns"], capture_output=True, check=True)
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


def check_root():
    """Check if running with root/admin privileges."""
    if get_platform() == "windows":
        try:
            import ctypes
            return ctypes.windll.shell32.IsUserAnAdmin() != 0
        except Exception:
            return False
    return os.geteuid() == 0


def require_root():
    """Exit with error if not running as root."""
    if not check_root():
        log_error("This command requires root privileges.")
        log_info(f"Run with: {Style.BOLD}sudo clishield <command>{Style.RESET}")
        sys.exit(1)


